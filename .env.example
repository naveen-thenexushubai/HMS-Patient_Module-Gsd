# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hospital_db
DB_USERNAME=hospital_app
DB_PASSWORD=<generate-secure-password>

# Admin User (for initial setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=<generate-secure-password>

# JWT Configuration
JWT_SECRET=<generate-64-char-base64-secret>
JWT_EXPIRATION_MS=3600000

# Encryption Configuration
ENCRYPTION_KEY=<generate-32-byte-base64-key>

# SSL/TLS Configuration (Production)
SSL_ENABLED=false
SSL_KEYSTORE_PATH=/path/to/keystore.p12
SSL_KEYSTORE_PASSWORD=<generate-secure-password>
SSL_KEY_ALIAS=hospital

# Application Environment
SPRING_PROFILES_ACTIVE=dev

# Instructions:
# 1. Copy this file to .env (never commit .env to Git)
# 2. Generate secure passwords: openssl rand -base64 32
# 3. Generate JWT secret (64 chars): openssl rand -base64 48
# 4. Generate encryption key (32 bytes): openssl rand -base64 32
# 5. Update values and keep secure
